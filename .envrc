# Automatically set up the development environment using direnv.
# Run `direnv allow` after cloning the repo.
#
# Requirements: uv (https://docs.astral.sh/uv/getting-started/installation/)

set -e

# Create and activate a Python venv managed by uv
export VIRTUAL_ENV="${PWD}/.venv"
if [ ! -d "$VIRTUAL_ENV" ]; then
  echo "Creating virtual environment with uv..."
  uv venv "$VIRTUAL_ENV"
fi
PATH_add "$VIRTUAL_ENV/bin"
export PATH

# Install/update dependencies when requirements.txt changes
REQUIREMENTS_HASH=$(sha256sum requirements.txt 2>/dev/null || shasum -a 256 requirements.txt)
HASH_FILE="${VIRTUAL_ENV}/.requirements-hash"
if [ ! -f "$HASH_FILE" ] || [ "$(cat "$HASH_FILE")" != "$REQUIREMENTS_HASH" ]; then
  echo "Installing dependencies..."
  uv pip install -r requirements.txt
  echo "$REQUIREMENTS_HASH" > "$HASH_FILE"
fi

# Install pre-commit hooks if not already installed
if [ ! -f .git/hooks/pre-commit ] || ! grep -q "pre-commit" .git/hooks/pre-commit 2>/dev/null; then
  echo "Installing pre-commit hooks..."
  pre-commit install
fi
